{
	"name": "pi-git-shortcuts",
	"version": "0.3.0",
	"description": "AI-assisted Git slash commands for Pi with isolated commit generation, push workflows, and conflict resolution.",
	"type": "module",
	"license": "MIT",
	"author": "LuckyYunPeng",
	"private": false,
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"git",
		"commit",
		"push",
		"conventional-commits",
		"rebase",
		"conflict-resolution",
		"context-isolation"
	],
	"files": [
		"src",
		"README.md",
		"README.zh-CN.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"check": "biome check . && npm run typecheck && npm test",
		"format": "biome check --write .",
		"test": "node --import tsx --test test/*.test.ts",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.80.7",
		"@earendil-works/pi-tui": ">=0.80.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@earendil-works/pi-coding-agent": "0.80.7",
		"@earendil-works/pi-tui": "0.80.7",
		"@types/node": "26.1.1",
		"tsx": "4.20.6",
		"typescript": "6.0.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LuckyYunPeng/pi-git-shortcuts.git"
	},
	"bugs": {
		"url": "https://github.com/LuckyYunPeng/pi-git-shortcuts/issues"
	},
	"homepage": "https://github.com/LuckyYunPeng/pi-git-shortcuts#readme",
	"publishConfig": {
		"access": "public"
	}
}
